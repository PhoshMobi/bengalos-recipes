#!/bin/sh

# Add BengalOS specific motd

set -e

cat >/etc/motd <<'EOF'
 ____                         _  ___  ____
| __ )  ___ _ __   __ _  __ _| |/ _ \/ ___|
|  _ \ / _ \ '_ \ / _` |/ _` | | | | \___ \
| |_) |  __/ | | | (_| | (_| | | |_| |___) |
|____/ \___|_| |_|\__, |\__,_|_|\___/|____/
                  |___/

    📱 https://bengalos.phosh.mobi/ 📱

EOF
